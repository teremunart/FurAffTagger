{
  "manifest_version": 3,
  "name": "FA Tag Autocomplete",
  "version": "1.4",
  "host_permissions": ["https://raw.githubusercontent.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.furaffinity.net/submit/*", "*://*.furaffinity.net/view/*", "*://*.furaffinity.net/full/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["style.css"],
      "matches": ["*://*.furaffinity.net/*"]
    }
  ]
}